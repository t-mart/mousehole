{
  "name": "mousehole",
  "version": "0.4.0",
  "type": "module",
  "private": true,
  "main": "src/index.ts",
  "module": "src/index.ts",
  "scripts": {
    "dev": "concurrently --names server,web --prefix-colors blue,magenta \"bun dev:server\" \"bun dev:web\"",
    "dev:server": "PUBLIC_GIT_HASH=$(git rev-parse --short HEAD) bun run --watch --no-clear-screen src/index.ts",
    "dev:web": "vite",
    "build": "vite build",
    "start": "PUBLIC_GIT_HASH=$(git rev-parse --short HEAD) NODE_ENV=production bun src/index.ts",
    "check:lint": "eslint src",
    "check:types": "tsc --noEmit",
    "check:test": "bun test",
    "fallow:dead-code": "bunx fallow dead-code",
    "fallow:dupes": "bunx fallow dupes",
    "fallow:health": "bunx fallow health"
  },
  "imports": {
    "#*": "./src/*"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^2.13.0",
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.101.0",
    "@types/bun": "^1.3.14",
    "@types/eslint-plugin-jsx-a11y": "^6.10.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unicorn": "^62.0.0",
    "globals": "^17.6.0",
    "lucide-react": "^0.562.0",
    "motion": "^12.40.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "type-fest": "^5.7.0",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "hono": "^4.12.25",
    "temporal-polyfill": "^0.3.2",
    "zod": "^4.4.3"
  }
}