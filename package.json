{
  "name": "mousehole",
  "version": "0.5.0",
  "type": "module",
  "private": true,
  "main": "src/index.ts",
  "module": "src/index.ts",
  "scripts": {
    "dev": "concurrently --names server,web --prefix-colors blue,magenta \"bun dev:server\" \"bun dev:web\"",
    "dev:server": "PUBLIC_GIT_HASH=$(git rev-parse --short HEAD) bun run --watch --no-clear-screen src/index.ts",
    "dev:web": "vite",
    "build": "vite build",
    "start": "PUBLIC_GIT_HASH=$(git rev-parse --short HEAD) NODE_ENV=production bun src/index.ts",
    "preview": "bun run build && bun run start",
    "demo": "bun run demo-fixtures/run.ts",
    "check:fmt": "bunx --bun prettier --check .",
    "check:lint": "bunx --bun eslint .",
    "check:types": "tsc --noEmit",
    "check:test": "bunx --bun vitest run",
    "fmt": "bunx --bun prettier --write .",
    "fallow:dead-code": "bunx fallow dead-code",
    "fallow:dupes": "bunx fallow dupes",
    "fallow:health": "bunx fallow health",
    "forum:build": "bun run forum-post/gen-html.ts",
    "forum:watch": "bun run --watch forum-post/gen-html.ts --watch"
  },
  "imports": {
    "#*": "./src/*"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^2.13.0",
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.101.0",
    "@types/bun": "^1.3.14",
    "@types/eslint-plugin-jsx-a11y": "^6.10.1",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/set-cookie-parser": "^2.4.10",
    "@vitejs/plugin-react": "^5.2.0",
    "cac": "^7.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unicorn": "^62.0.0",
    "globals": "^17.6.0",
    "gray-matter": "^4.0.3",
    "juice": "^12.1.1",
    "lucide-react": "^0.562.0",
    "motion": "^12.40.0",
    "prettier": "3.8.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rehype-raw": "^7.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-directive": "^4.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "type-fest": "^5.7.0",
    "typescript-eslint": "^8.61.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "hono": "^4.12.25",
    "set-cookie-parser": "^3.1.0",
    "temporal-polyfill": "^0.3.2",
    "zod": "^4.4.3"
  }
}
