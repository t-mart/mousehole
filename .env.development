# Environment variables for development. These can be overridden by creating a
# `.env.local` file with the same variables.
MOUSEHOLE_CHECK_INTERVAL_SECONDS=10 # quick intervals 
MOUSEHOLE_STATE_DIR_PATH=./.state # use a local state directory for development
MOUSEHOLE_AUTH_PASSWORD=password
PUBLIC_DEMO_MODE=false # don't be in demo mode. this must be set because it will be inlined (not able to have a default)

# Demo mode for taking screenshots, toggle by commenting/uncommenting
# PUBLIC_DEMO_MODE=true # show fake IP and AS in the UI
# MOUSEHOLE_CHECK_INTERVAL_SECONDS=300 # revert to production value